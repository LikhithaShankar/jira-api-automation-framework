{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Get Issue Response Schema",
  "type": "object",
  "required": ["id", "key", "fields"],
  "properties": {
    "id": {
      "type": "string"
    },
    "key": {
      "type": "string",
      "pattern": "^[A-Z]+-\\d+$"
    },
    "fields": {
      "type": "object",
      "required": ["summary", "project", "issuetype"],
      "properties": {
        "summary": {
          "type": "string"
        },
        "project": {
          "type": "object",
          "required": ["key"],
          "properties": {
            "key": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "issuetype": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}